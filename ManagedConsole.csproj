<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- CMake build tree holding the generated Interop.csproj; the
         managed_console CMake target overrides this per preset. -->
    <NativeBuildDir>$(MSBuildThisFileDirectory)out\build\x64-debug</NativeBuildDir>
  </PropertyGroup>

  <ItemGroup>
    <!-- Keep the SDK's *.cs glob out of the CMake build tree: the SWIG output
         under out/ defines the same types as the referenced project. -->
    <Compile Remove="out\**" />
    <!-- SWIG wrapper project generated by interop/csharp/CMakeLists.txt; it
         brings the managed assembly and the native libraries with it. -->
    <ProjectReference Include="$(NativeBuildDir)\interop\csharp\Interop.csproj" />
  </ItemGroup>

</Project>
