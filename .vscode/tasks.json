{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake configure (linux-debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "linux-debug"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "CMake build (linux-debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "out/build/linux-debug", "--target", "managed_console"],
      "options": { "cwd": "${workspaceFolder}" },
      "dependsOn": "CMake configure (linux-debug)",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    }
  ]
}
